# ══════════════════════════════════════════════════════════════════
#  ExpressFood — .gitignore
#  Android + Kotlin + Firebase + Node.js
# ══════════════════════════════════════════════════════════════════

# ── Gradle ────────────────────────────────────────────────────────
.gradle/
gradle-wrapper.jar          # se regenera con `gradle wrapper`
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar  # excepción: sí se versiona este

# ── Android Studio / IntelliJ ─────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
local.properties            # contiene paths absolutos del SDK local
captures/
.externalNativeBuild/
.cxx/

# ── Artefactos de compilación ─────────────────────────────────────
*.apk
*.aab
*.ap_
*.dex
*.class
out/
bin/
gen/
proguard/

# ── macOS ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Firebase / Google — NUNCA subir claves privadas ───────────────
google-services.json
scripts/service-account-key.json
*.p12
*.jks                       # keystore de firma (producción)
*.keystore
release.properties

# ── Variables de entorno y secretos ───────────────────────────────
.env
.env.*
!.env.example               # sí se puede versionar el ejemplo

# ── Node.js (scripts/ de Firestore) ──────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json           # opcional: omitir si no se usa npm ci en CI
.npm

# ── Logs generales ────────────────────────────────────────────────
*.log
logs/

# ── Archivos temporales del SO ────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
*~
CLAUDE.md

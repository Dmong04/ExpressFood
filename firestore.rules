rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'ADMIN';
    }

    function isClient() {
      return isAuthenticated() && getUserData().role == 'CLIENT';
    }

    // ─── users/{uid} ────────────────────────────────────────────────────────
    // El propio usuario puede leer/actualizar su perfil.
    // Solo el admin puede leer todos los perfiles.
    // La creación la hace el propio usuario al registrarse (Google SSO).

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasAll(['email', 'displayName', 'role', 'createdAt'])
                    && request.resource.data.role == 'CLIENT'; // nuevo usuario siempre CLIENT
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── products/{productId} ───────────────────────────────────────────────
    // Cualquier usuario autenticado puede ver el menú.
    // Solo el admin puede crear/editar/borrar productos.

    match /products/{productId} {
      allow read:   if isAuthenticated();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ─── orders/{orderId} ───────────────────────────────────────────────────
    // Cliente: puede crear órdenes propias y cancelarlas mientras estén PENDING.
    // Admin:   puede leer todas y cambiar cualquier estado.

    match /orders/{orderId} {
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isClient()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'PENDING';

      allow update: if isAdmin()
                    || (
                      isClient()
                      && resource.data.userId == request.auth.uid
                      && resource.data.status == 'PENDING'
                      && request.resource.data.status == 'CANCELLED'
                    );

      allow delete: if isAdmin();
    }

    // ─── order_items/{itemId} ───────────────────────────────────────────────
    // Los items siguen los permisos de su orden padre.

    match /order_items/{itemId} {
      allow read: if isAuthenticated()
                  && (
                    get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.userId
                      == request.auth.uid
                    || isAdmin()
                  );

      allow create: if isClient();
      allow update,
            delete: if isAdmin();
    }
  }
}
